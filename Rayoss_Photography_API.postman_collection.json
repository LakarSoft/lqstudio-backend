									"description": "Date in YYYY-MM-DD format"
								},
								{
									"key": "packageId",
									"value": "pkg-early-bird",
									"description": "Package ID (optional, defaults to pkg-early-bird)"
								}
							],
							"variable": [
								{
									"key": "themeId",
									"value": "theme-minimalist",
									"description": "Theme ID to check availability for"
								}
							]
						},
						"description": "Check available time slots for a specific theme on a specific date"
					},
					"response": []
