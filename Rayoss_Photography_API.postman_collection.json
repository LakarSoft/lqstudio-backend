{
	"info": {
		"_postman_id": "lqstudio-photography-api",
		"name": "LQ Studio Photography Booking API",
		"description": "Complete API collection for LQ Studio Photography Studio booking system. Includes public endpoints for customers and protected admin endpoints for management.\n\n## Setup Instructions\n1. Update the `baseUrl` variable with your server address (default: http://localhost:8080)\n2. For admin endpoints, first login via `/api/admin/login` to get JWT token\n3. The token will be automatically used in protected endpoints via the `bearerToken` variable\n\n## Base URL\nDefault: http://localhost:8080",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "bearerToken",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "Check if the API server and database are healthy"
					},
					"response": []
				}
			],
			"description": "Health check endpoint to verify API availability"
		},
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Admin Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Auto-save token to environment variable",
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.data && jsonData.data.token) {",
									"        pm.collectionVariables.set(\"bearerToken\", jsonData.data.token);",
									"        console.log(\"Token saved:\", jsonData.data.token);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@lqstudio.com\",\n  \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/admin/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "admin", "login"]
						},
						"description": "Admin login to get JWT token. Token is automatically saved to `bearerToken` variable for use in protected endpoints."
					},
					"response": []
				}
			],
			"description": "Authentication endpoints for admin users"
		},
