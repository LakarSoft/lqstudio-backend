								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"packageId\": \"pkg-early-bird\",\n  \"slots\": [\n    {\n      \"date\": \"2024-12-25\",\n      \"time\": \"10:00\",\n      \"themeId\": \"theme-minimalist\"\n    },\n    {\n      \"date\": \"2024-12-26\",\n      \"time\": \"14:00\",\n      \"themeId\": \"theme-vintage\"\n    }\n  ],\n  \"addons\": [\n    {\n      \"addonId\": \"addon-extra-person\",\n      \"quantity\": 2\n    },\n    {\n      \"addonId\": \"addon-printed-photos\",\n      \"quantity\": 1\n    }\n  ],\n  \"customer\": {\n    \"name\": \"John Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"phone\": \"+60123456789\",\n    \"notes\": \"Please call me 1 day before the session\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/bookings",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings"]
						},
						"description": "Create a new booking (customer-facing, no authentication required). Supports 1-3 slots, optional add-ons, and customer information."
					},
					"response": []
				},
