								{
									"key": "id",
									"value": "booking-id-here",
									"description": "Booking ID"
								}
							]
						},
						"description": "Get booking details by ID (public, for customers to check their booking)"
					},
					"response": []
				},
				{
					"name": "Upload Payment Screenshot",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": [],
									"description": "Payment screenshot image file (JPG, PNG, JPEG)"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/bookings/:id/payment-screenshot",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings", ":id", "payment-screenshot"],
							"variable": [
								{
									"key": "id",
									"value": "booking-id-here",
									"description": "Booking ID"
								}
							]
						},
						"description": "Upload payment screenshot for a booking. Accepts image files (jpg, jpeg, png). Max file size: 5MB."
					},
					"response": []
				}
			],
			"description": "Public booking endpoints (no authentication required)"
